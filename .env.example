# ─────────────────────────────────────────────────────
# VENKE Finance Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── JWT Authentication ────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ─── Database ──────────────────────────────────────────
# Leave blank to use local SQLite (development/local use)
# Set to your PostgreSQL connection string for cloud:
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Set to 'false' only for local PostgreSQL without SSL
DATABASE_SSL=true

# ─── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# Example: https://myfinance.onrender.com,https://www.myfinance.com
ALLOWED_ORIGINS=https://your-app.onrender.com

# ─── Cloudinary (Cloud File Storage) ──────────────────
# Get these from https://cloudinary.com/console
# Leave blank to use local disk storage (not suitable for cloud hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
